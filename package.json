{
  "name": "modelglass-router-examples",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Worked examples of building on the live Modelglass pricing and capability feed",
  "exports": {
    "./pricing-math": {
      "types": "./pricing-math/dist/index.d.ts",
      "import": "./pricing-math/dist/index.js"
    }
  },
  "scripts": {
    "route": "node --import tsx/esm cost-aware-vscode-router/src/route.ts",
    "demo": "node --import tsx/esm cost-aware-vscode-router/src/route.ts --demo",
    "report": "node --import tsx/esm cost-aware-vscode-router/src/report.ts",
    "summary": "node --import tsx/esm cost-aware-vscode-router/src/summary.ts",
    "refine": "node --import tsx/esm av-prompt-refiner/src/refine.ts",
    "watch": "node --import tsx/esm stack-watch/src/watch.ts",
    "cost": "node --import tsx/esm image-batch-coster/src/cost.ts",
    "check": "node --import tsx/esm switch-check/src/check.ts",
    "plan": "node --import tsx/esm shot-plan-compiler/src/plan.ts",
    "test": "node --import tsx/esm --test cost-aware-vscode-router/src/*.test.ts av-prompt-refiner/src/*.test.ts stack-watch/src/*.test.ts image-batch-coster/src/*.test.ts switch-check/src/*.test.ts shot-plan-compiler/src/*.test.ts",
    "build:pricing-math": "tsc -p pricing-math/tsconfig.json",
    "prepare": "npm run build:pricing-math"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
